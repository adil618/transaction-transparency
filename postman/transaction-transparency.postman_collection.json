      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Donor One\",\n  \"email\": \"donor1@demo.com\",\n  \"password\": \"password123\",\n  \"role\": \"DONOR\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
